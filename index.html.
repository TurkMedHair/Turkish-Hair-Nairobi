<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TurkMed | Advanced Hair Restoration Nairobi</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-dark: #040b14; /* Deep Navy Gemini Style */
            --sidebar-dark: #0a131f;
            --text-main: #e3e3e3;
            --accent-red: #B22222; /* TurkMed Red */
            --accent-blue: #1a73e8;
        }

        body, html {
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-main);
            height: 100%;
            overflow: hidden;
        }

        /* Layout Container */
        .container {
            display: flex;
            height: 100vh;
        }

        /* Sidebar - Gemini Style */
        .sidebar {
            width: 260px;
            background-color: var(--sidebar-dark);
            padding: 20px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            border-right: 1px solid #1e293b;
        }

        .logo {
            font-size: 22px;
            font-weight: 600;
            letter-spacing: 1px;
        }
        .logo span { color: var(--accent-red); }

        .nav-links div {
            margin: 20px 0;
            color: #9ca3af;
            cursor: pointer;
            transition: 0.3s;
        }
        .nav-links div:hover { color: white; }

        /* Main Chat Area */
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
            position: relative;
        }

        .hero-text {
            text-align: center;
            max-width: 800px;
            margin-bottom: 50px;
        }

        .hero-text h1 {
            font-size: 48px;
            background: linear-gradient(to right, #ffffff, var(--accent-red));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 10px;
        }

        /* Action Cards */
        .cards-container {
            display: flex;
            gap: 15px;
            margin-bottom: 100px;
        }

        .card {
            background: #111b27;
            padding: 20px;
            border-radius: 12px;
            width: 180px;
            cursor: pointer;
            border: 1px solid transparent;
            transition: 0.3s;
        }

        .card:hover {
            border-color: var(--accent-red);
            background: #162435;
        }

        /* Input Bar - Gemini Style */
        .input-container {
            position: absolute;
            bottom: 40px;
            width: 100%;
            max-width: 800px;
        }

        .search-bar {
            background: #1e293b;
            border-radius: 30px;
            padding: 15px 25px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .search-bar input {
            background: transparent;
            border: none;
            color: white;
            width: 85%;
            font-size: 16px;
            outline: none;
        }

        .btn-consult {
            background: var(--accent-red);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 20px;
            cursor: pointer;
            font-weight: 600;
        }

        .contact-footer {
            font-size: 12px;
            color: #64748b;
            margin-top: 15px;
            text-align: center;
        }

        a { text-decoration: none; color: inherit; }
    </style>
</head>
<body>

<div class="container">
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="logo">Turk<span>Med</span></div>
        <div class="nav-links">
            <div>Home</div>
            <div>About Parklands Clinic</div>
            <div>FUE & DHI Results</div>
            <div>Aftercare (10-Day Wash)</div>
        </div>
        <div class="contact-info" style="font-size: 14px; color: #9ca3af;">
            <p>📍 Parklands, Nairobi</p>
            <p>📞 0726 618 187</p>
        </div>
    </div>

    <!-- Main Section -->
    <div class="main-content">
        <div class="hero-text">
            <h1>Hello, I'm TurkMed</h1>
            <p style="font-size: 20px; color: #9ca3af;">How can I help you restore your hair and confidence today?</p>
        </div>

        <div class="cards-container">
            <a href="https://wa.me/254143074887" class="card">
                <p>Book a Free Assessment</p>
            </a>
            <a href="https://wa.me/254143074887" class="card">
                <p>View Price Estimation</p>
            </a>
            <a href="https://wa.me/254143074887" class="card">
                <p>Turkish FUE Techniques</p>
            </a>
        </div>

        <div class="input-container">
            <div class="search-bar">
                <input type="text" placeholder="Ask about hair transplant costs or procedures...">
                <button class="btn-consult" onclick="location.href='https://wa.me/254143074887'">Chat on WhatsApp</button>
            </div>
            <p class="contact-footer">
                Official TurkMed Clinic Nairobi. 0143 074 887 | info@turkmed.co.ke
            </p>
        </div>
    </div>
</div>

</body>
</html>
